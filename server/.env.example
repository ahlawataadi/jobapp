NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/jobapp

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS
CLIENT_URL=http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# Admin bootstrap (used by seed script)
ADMIN_EMAIL=admin@jobapp.local
ADMIN_PASSWORD=ChangeMe123!

# File storage
# Leave STORAGE_DRIVER unset (or "local") to store uploads on local disk and
# serve them from /uploads. Set it to "s3" to push uploads to an S3 bucket.
# See docs/S3_SETUP.md for the full guide.
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: a CDN/CloudFront domain in front of the bucket. If unset, the
# bucket's default https URL is used.
S3_PUBLIC_URL=
