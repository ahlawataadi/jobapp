NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/jobapp

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS
CLIENT_URL=http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# Admin bootstrap (used by seed script)
ADMIN_EMAIL=admin@jobapp.local
ADMIN_PASSWORD=ChangeMe123!

# File storage (Cloudflare R2)
# Leave STORAGE_DRIVER unset (or "local") to store uploads on local disk and
# serve them from /uploads. Set it to "r2" to push uploads to a Cloudflare R2
# bucket. See docs/R2_SETUP.md for the full guide.
STORAGE_DRIVER=local
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public bucket URL — the r2.dev domain or a custom domain mapped to the bucket.
# Required for uploaded files to be publicly viewable.
R2_PUBLIC_URL=
